{
  "name": "supaviz",
  "version": "1.0.0",
  "private": true,
  "description": "Visualize your Supabase schema as an ERD instantly — free and open source",
  "homepage": "https://aaroncx.github.io/supaviz",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src"
  },
  "keywords": ["supabase", "postgresql", "erd", "schema", "visualizer", "react", "open-source"],
  "license": "MIT",
  "dependencies": {
    "@uiw/react-codemirror": "^4.23.0",
    "@codemirror/lang-sql": "^6.8.0",
    "@xyflow/react": "^12.4.0",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.45",
    "prettier": "^3.5.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
